{
  "name": "library-typescript",
  "$schema": "../node_modules/nx/schemas/project-schema.json",
  "projectType": "library",
  "sourceRoot": "library-typescript/src",
  "targets": {
    "lint": {
      "executor": "nx:run-commands",
      "options": {
        "command": "biome check",
        "cwd": "{projectRoot}"
      },
      "inputs": [
        "{projectRoot}/src/**/*",
        "{projectRoot}/test/**/*",
        "{projectRoot}/biome.json"
      ]
    },
    "format": {
      "executor": "nx:run-commands",
      "options": {
        "command": "biome check --write",
        "cwd": "{projectRoot}"
      },
      "cache": false
    },
    "docs": {
      "executor": "nx:run-commands",
      "options": {
        "command": "typedoc",
        "cwd": "{projectRoot}"
      },
      "inputs": [
        "{projectRoot}/src/**/*",
        "{projectRoot}/tsconfig.json",
        "{projectRoot}/typedoc.json"
      ],
      "outputs": ["{projectRoot}/docs"]
    }
  }
}
